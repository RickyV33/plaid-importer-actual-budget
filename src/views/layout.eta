<!doctype html>
<html lang="<%= it.locale ?? 'en' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= it.title ?? "plaid-importer" %></title>
    <link rel="stylesheet" href="/static/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer" />
    <!-- Client i18n catalog. In <head> so page scripts can read it on parse. -->
    <script id="i18n-data" type="application/json"><%~ it.i18nClient %></script>
  </head>
  <body>
    <header class="topbar">
      <a href="/" class="brand">Plaid Importer <span class="brand-sub">for Actual Budget</span></a>
      <nav>
        <% if (it.authed) { %>
          <a href="/"><%= it.t("nav.home") %></a>
          <a href="/schedules"><%= it.t("nav.schedules") %></a>
          <a href="/history"><%= it.t("nav.history") %></a>
          <% if (it.isAdmin) { %>
            <a href="/settings"><%= it.t("nav.settings") %></a>
          <% } %>
          <form method="post" action="/logout" class="inline">
            <button type="submit" class="linklike"><%= it.t("nav.logout") %></button>
          </form>
        <% } %>
      </nav>
    </header>
    <% if (it.banners && it.banners.length > 0) { %>
      <div class="app-banners">
        <% it.banners.forEach(function(b) { %>
          <div class="app-banner app-banner-<%= b.type %>" data-banner-key="<%= b.key %>">
            <span><%~ it.t("banners." + b.key) %></span>
            <button type="button" class="banner-dismiss" aria-label="Dismiss">×</button>
          </div>
        <% }) %>
      </div>
    <% } %>
    <main>
      <%~ it.body %>
    </main>
    <script>
      (function () {
        document.querySelectorAll('.banner-dismiss').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var banner = btn.closest('.app-banner');
            var key = banner && banner.dataset.bannerKey;
            if (!key) return;
            fetch('/banners/' + encodeURIComponent(key) + '/dismiss', { method: 'POST' });
            banner.remove();
          });
        });
      })();
    </script>
  </body>
</html>
