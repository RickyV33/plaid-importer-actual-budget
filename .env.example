# =================================================================
# plaid-importer — environment variables
#
# Copy to `.env` for local dev. In production, supply via your
# container orchestrator's secret store (never check `.env` in).
# =================================================================

# ─── App ─────────────────────────────────────────────────────────
APP_PORT=8080
APP_BIND=0.0.0.0
# APP_URL MUST be the public HTTPS URL the reverse proxy serves.
# Used as the base of the Plaid OAuth redirect URI and for Link.
# Example (production): https://plaid-importer.example.com
APP_URL=http://localhost:8080
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────
# APP_USER / APP_PASSWORD are now SEED-ONLY: on first boot, if the users
# table is empty, an admin account is created from these values. After the
# first user exists they are ignored — accounts live in the database and new
# users self-register at /register (gated by a secret the admin sets under
# /settings). The very first registrant (if you don't rely on the env seed)
# becomes admin automatically.
#
# Note: the registration secret is NOT an env var — it lives in the database
# and is set/rotated by an admin in the /settings page after login.
APP_USER=admin
APP_PASSWORD=changeme
# 32+ random bytes; generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional: brute-force protection on POST /login and POST /register
LOGIN_RATELIMIT_MAX=5
LOGIN_RATELIMIT_WINDOW_MS=60000

# ─── Plaid ───────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | production
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=US
PLAID_LANGUAGE=en
PLAID_PRODUCTS=transactions
# Required for OAuth banks (Chase, BoA, etc). MUST exactly match the
# URI registered in the Plaid dashboard. Typically: ${APP_URL}/link/oauth-return
PLAID_REDIRECT_URI=

# ─── Actual ──────────────────────────────────────────────────────
ACTUAL_SERVER_URL=https://budget.jankbyrick.com
ACTUAL_SERVER_PASSWORD=
# From Actual → Settings → Advanced → Sync ID
ACTUAL_SYNC_ID=
# Only if your budget uses end-to-end encryption
ACTUAL_ENCRYPTION_PASSWORD=

# ─── Storage ─────────────────────────────────────────────────────
DATABASE_PATH=./data/plaid-importer.db
ACTUAL_CACHE_DIR=./data/actual-cache
# 32-byte AES-256-GCM key; generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ─── Optional ────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
