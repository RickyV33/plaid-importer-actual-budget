{
  "name": "plaid-importer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/views dist/db/migrations && cp src/views/*.eta dist/views/ && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "smoke": "tsx scripts/smoke.ts",
    "test": "node --test --import tsx/esm \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@actual-app/api": "^26.5.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "eta": "^4.6.0",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "plaid": "^42.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
